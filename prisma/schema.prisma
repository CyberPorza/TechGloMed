// =============================================================================
// TechGloMed — Prisma Schema
// Sprint 0: Domain model skeletons. Fields will be expanded in Sprint 1+.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  DOCTOR
  PATIENT
  SUPPORT
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DELETED
}

enum DoctorVerificationStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum NotificationType {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

// ── Core Models ───────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  role         UserRole   @default(PATIENT)
  status       UserStatus @default(PENDING_VERIFICATION)

  // Relations
  doctor        Doctor?
  patient       Patient?
  notifications Notification[]

  // Audit fields
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // soft delete

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model Doctor {
  id                 String                  @id @default(uuid())
  userId             String                  @unique @map("user_id")
  licenseNumber      String                  @unique @map("license_number")
  specialization     String
  verificationStatus DoctorVerificationStatus @default(PENDING) @map("verification_status")
  bio                String?
  yearsOfExperience  Int?                    @map("years_of_experience")
  consultationFee    Decimal                 @default(0) @map("consultation_fee") @db.Decimal(10, 2)
  rating             Decimal                 @default(0) @db.Decimal(3, 2)
  totalReviews       Int                     @default(0) @map("total_reviews")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  reviews      Review[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([specialization])
  @@index([verificationStatus])
  @@map("doctors")
}

model Patient {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  dateOfBirth DateTime? @map("date_of_birth")
  gender      String?
  phoneNumber String?   @map("phone_number")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("patients")
}

model Appointment {
  id              String            @id @default(uuid())
  doctorId        String            @map("doctor_id")
  patientId       String            @map("patient_id")
  scheduledAt     DateTime          @map("scheduled_at")
  durationMinutes Int               @default(30) @map("duration_minutes")
  status          AppointmentStatus @default(SCHEDULED)
  notes           String?
  videoSessionUrl String?           @map("video_session_url")

  // Relations
  doctor  Doctor   @relation(fields: [doctorId], references: [id])
  patient Patient  @relation(fields: [patientId], references: [id])
  payment Payment?
  review  Review?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([doctorId])
  @@index([patientId])
  @@index([scheduledAt])
  @@index([status])
  @@map("appointments")
}

model Payment {
  id            String        @id @default(uuid())
  appointmentId String        @unique @map("appointment_id")
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD")
  status        PaymentStatus @default(PENDING)
  provider      String?       // e.g. "stripe"
  providerTxId  String?       @unique @map("provider_tx_id")
  refundedAt    DateTime?     @map("refunded_at")

  // Relations
  appointment Appointment @relation(fields: [appointmentId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("payments")
}

model Review {
  id            String @id @default(uuid())
  appointmentId String @unique @map("appointment_id")
  doctorId      String @map("doctor_id")
  rating        Int    // 1-5
  comment       String?

  // Relations
  appointment Appointment @relation(fields: [appointmentId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([doctorId])
  @@map("reviews")
}

model Notification {
  id      String             @id @default(uuid())
  userId  String             @map("user_id")
  type    NotificationType
  status  NotificationStatus @default(QUEUED)
  subject String?
  body    String
  sentAt  DateTime?          @map("sent_at")
  readAt  DateTime?          @map("read_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@map("notifications")
}
