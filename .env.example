# =============================================================================
# TechGloMed API — Environment Configuration Template
# Copy this file to .env and fill in values. NEVER commit .env to source control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_NAME=TechGloMed API
APP_VERSION=0.1.0
API_GLOBAL_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=techglommed
DATABASE_PASSWORD=change_me_in_production
DATABASE_NAME=techglommed_db
DATABASE_SCHEMA=public
# Prisma uses this composite URL
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?schema=${DATABASE_SCHEMA}
# Connection pool
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=3600

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_a_long_random_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_another_long_random_secret_min_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Throttling / Rate Limiting ────────────────────────────────────────────────
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_PRETTY_PRINT=true

# ── Swagger ───────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
SWAGGER_TITLE=TechGloMed API
SWAGGER_DESCRIPTION=Global Telemedicine Platform — REST API Documentation
